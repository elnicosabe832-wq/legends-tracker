# Pega estas líneas (sin comillas). Reinicia npm run dev tras cambiarlas.

OPENAI_API_KEY=

# Supabase — Dashboard → Settings → API
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co

# Usa UNA de estas claves (no pegues la clave suelta, siempre NOMBRE=valor):
# Nuevo (recomendado): pestaña "API Keys" → Publishable key
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Legacy: pestaña "Legacy API Keys" → anon public
# VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Service role (solo servidor, NUNCA en el frontend) — webhooks Pro + pagos
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Stripe Pro 1,99€/mes — https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# URL de la app (checkout vuelve aquí)
APP_URL=http://localhost:5173

# Producción (Render): orígenes permitidos, URL exacta de Vercel
# CORS_ORIGINS=https://tu-app.vercel.app

# Producción (Vercel): URL del API en Render, sin barra final
# VITE_API_URL=https://tu-api.onrender.com
